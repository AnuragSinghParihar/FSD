{
  "family": "shopmart-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::956202003884:role/LabRole",
  "taskRoleArn": "arn:aws:iam::956202003884:role/LabRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "956202003884.dkr.ecr.us-east-1.amazonaws.com/shopmart/backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "DB_HOST", "value": "shopmart-db.cc5goxutxb1z.us-east-1.rds.amazonaws.com" },
        { "name": "DB_PORT", "value": "3306" },
        { "name": "DB_NAME", "value": "shopmart" },
        { "name": "DB_USER", "value": "admin" },
        { "name": "FRONTEND_URL", "value": "http://52.205.6.44" }
      ],
      "secrets": [
        {
          "name": "DB_PASS",
          "valueFrom": "arn:aws:ssm:us-east-1:956202003884:parameter/shopmart/prod/db-pass"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-1:956202003884:parameter/shopmart/prod/jwt-secret"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:3000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/shopmart-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
